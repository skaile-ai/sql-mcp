{
  "name": "@skaile/sql-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Portable SQL MCP server (PostgreSQL, MySQL, SQLite, MSSQL)",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "sql-mcp": "dist/server.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "RUN_DB_INTEGRATION=1 vitest run tests/integration",
    "test:watch": "vitest",
    "build": "bun run build.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "mysql2": "^3.22.5",
    "pg": "^8.21.0",
    "tedious": "^19.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "testcontainers": "^12.0.2",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  }
}
